# =============================================================================
# 1. SENSITIVE & ENVIRONMENT-SPECIFIC FILES (MOST IMPORTANT)
# =============================================================================
# Never commit your secret API keys, database passwords, or other credentials.
# This is the most critical section of this file.
.env
.env.*
*.env

# =============================================================================
# 2. PYTHON & BACKEND-SPECIFIC
# =============================================================================

# Python virtual environment
# Contains thousands of files and is specific to your local machine.
/backend/.venv/
.venv/

# Python bytecode and cache
# These are auto-generated and can cause merge conflicts.
__pycache__/
*.pyc
*.pyo
*.pyd

# Build and distribution artifacts
dist/
build/
*.egg-info/
*.egg

# Flask instance folder
# Can contain local configuration or temporary databases.
instance/

# =============================================================================
# 3. JAVASCRIPT & FRONTEND-SPECIFIC (React / Vite / Node.js)
# =============================================================================

# Node.js dependencies
# This folder is massive and can be regenerated by running `npm install`.
/frontend/node_modules/
node_modules/

# Vite build output
# This is the compiled, production version of your app.
/frontend/dist/
dist/

# Vite cache
# Temporary files used by the Vite development server.
/frontend/.vite/
.vite/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# 4. IDE & OPERATING SYSTEM-SPECIFIC
# =============================================================================

# JetBrains IDEs (PyCharm, WebStorm, etc.)
.idea/

# VSCode
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db